      "title": "Realized P/L by Symbol",
      "type": "table",
      "targets": [
        {
          "rawSql": "SELECT \"symbol\", \"cumulative_pnl\", \"deal_count\" FROM grafana_realized_pnl ORDER BY cumulative_pnl DESC",
